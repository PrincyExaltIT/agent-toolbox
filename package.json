{
  "name": "@princyexaltit/agent-toolbox",
  "version": "0.2.1",
  "description": "Personal multi-profile agent toolbox CLI — install / switch / toggle profiles for Claude Code, Copilot VS Code, Copilot CLI, and Codex.",
  "type": "module",
  "bin": {
    "agent-toolbox": "./dist/cli.js",
    "at": "./dist/cli.js"
  },
  "files": [
    "dist",
    "guidelines",
    "README.md"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PrincyExaltIT/agent-toolbox.git"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "commander": "^14.0.0",
    "kleur": "^4.1.5",
    "omelette": "^0.4.17",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/omelette": "^0.4.5",
    "typescript": "^5.7.0"
  }
}
